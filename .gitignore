# ============================================================
# .gitignore — ecommerce-tool-calling-agent
# ============================================================

# ----------------------------------------------------------------------
# 환경변수 / 인증 정보 (절대 커밋하면 안 됨)
# ----------------------------------------------------------------------
.env
*.env
.env.*
!.env.example          # 예시 파일은 커밋 허용

# ----------------------------------------------------------------------
# 데이터 파일 (용량이 크고 재생성 가능)
# ----------------------------------------------------------------------
# SQLite DB 파일
*.db
*.sqlite
*.sqlite3

# 수집된 데이터 디렉토리
naver_shopping_data/
airflow/data/

# 이미지 파일 (CLIP 임베딩용으로 다운로드한 것들)
*.jpg
*.jpeg
*.png
*.webp
*.gif

# CSV 내보내기 결과
*.csv

# ----------------------------------------------------------------------
# dbt 산출물 (빌드 시 자동 생성)
# ----------------------------------------------------------------------
dbt/naver_shop/target/
dbt/naver_shop/logs/
dbt/naver_shop/dbt_packages/

# ----------------------------------------------------------------------
# Airflow 런타임 파일 (컨테이너가 생성, 커밋 불필요)
# ----------------------------------------------------------------------
airflow/logs/
airflow/plugins/

# ----------------------------------------------------------------------
# Python 관련
# ----------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.Python

# 가상환경
.venv/
venv/
env/
.naver_crawling/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# mypy
.mypy_cache/

# ----------------------------------------------------------------------
# 벡터DB 로컬 저장소 (나중에 Chroma/Qdrant 쓸 때)
# ----------------------------------------------------------------------
chroma_db/
qdrant_storage/
vector_store/

# ----------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------
# Docker 볼륨 데이터는 커밋 불필요 (postgres 메타데이터 등)
postgres-db-volume/

# ----------------------------------------------------------------------
# IDE / OS
# ----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------
# 기타 빌드 산출물
# ----------------------------------------------------------------------
dist/
build/
*.egg-info/
.eggs/
*.bak